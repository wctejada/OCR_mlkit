<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.58" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cameraFrame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/guideline">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/imgCapturada"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            android:contentDescription="Imagen capturada"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/scannerOverlay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="#80000000"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Marco del OCR ajustable -->
        <View
            android:id="@+id/scannerFrame"
            android:layout_width="300dp"
            android:layout_height="200dp"
            android:background="@drawable/scanner_frame_border"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Handle para redimensionar el marco -->
        <ImageView
            android:id="@+id/resizeHandle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_crop"
            android:padding="4dp"
            android:background="#80000000"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/scannerFrame"
            app:layout_constraintEnd_toEndOf="@id/scannerFrame"
            app:tint="#64B5F6" />

        <!-- OverlayContainer ahora mide lo mismo que scannerFrame -->
        <FrameLayout
            android:id="@+id/overlayContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@id/scannerFrame"
            app:layout_constraintBottom_toBottomOf="@id/scannerFrame"
            app:layout_constraintStart_toStartOf="@id/scannerFrame"
            app:layout_constraintEnd_toEndOf="@id/scannerFrame" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCambiarIdioma"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginStart="12dp"
            android:text="Inglés → Español"
            android:textColor="#FFFFFF"
            android:backgroundTint="#B3000000"
            app:strokeColor="#64B5F6"
            app:strokeWidth="1dp"
            android:textSize="10sp"
            app:cornerRadius="20dp"
            app:icon="@android:drawable/ic_menu_sort_alphabetically"
            app:iconGravity="textStart"
            app:iconSize="14dp"
            app:iconTint="#64B5F6"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/badgeModo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/badge_background"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="● LIVE"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerOriginal"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Ver Original"
            android:textColor="#FFFFFF"
            android:backgroundTint="#80000000"
            android:textSize="10sp"
            android:visibility="gone"
            app:cornerRadius="20dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:layout_constraintTop_toTopOf="@id/btnCambiarIdioma"
            app:layout_constraintBottom_toBottomOf="@id/btnCambiarIdioma"
            app:layout_constraintStart_toEndOf="@id/btnCambiarIdioma" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnCapturar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:contentDescription="Capturar foto"
                android:visibility="gone"
                app:srcCompat="@android:drawable/ic_menu_camera"
                app:tint="@android:color/white"
                app:backgroundTint="#CC1976D2"
                app:fabSize="normal" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTraducir"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:layout_marginEnd="16dp"
                android:text="TRADUCIR"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E91E63"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:cornerRadius="28dp"
                app:icon="@android:drawable/ic_menu_send" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnReanudar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:contentDescription="Reanudar live"
                android:visibility="gone"
                app:srcCompat="@android:drawable/ic_media_play"
                app:tint="@android:color/white"
                app:backgroundTint="#CC388E3C"
                app:fabSize="normal" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnGaleria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Abrir galería"
                android:visibility="gone"
                app:srcCompat="@android:drawable/ic_menu_gallery"
                app:tint="@android:color/white"
                app:backgroundTint="#CC7B1FA2"
                app:fabSize="normal" />

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/controlsCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/guideline"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Texto detectado"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/txtOriginal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="60dp"
                    android:background="#1A000000"
                    android:padding="12dp"
                    android:text="Apunta la cámara al texto..."
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Traducción"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/txtTraducido"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="60dp"
                    android:background="#1A1976D2"
                    android:padding="12dp"
                    android:text=""
                    android:textColor="#1565C0"
                    android:textSize="14sp" />

            </LinearLayout>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
