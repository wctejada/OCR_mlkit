<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <!-- Círculo decorativo superior -->
    <View
        android:id="@+id/circleTop"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:background="@drawable/circle_glow"
        android:alpha="0.18"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-80dp"
        android:layout_marginEnd="-80dp" />

    <!-- Círculo decorativo inferior -->
    <View
        android:id="@+id/circleBottom"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/circle_glow_accent"
        android:alpha="0.14"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="-60dp"
        android:layout_marginStart="-60dp" />

    <!-- Ícono -->
    <ImageView
        android:id="@+id/appIcon"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@drawable/outline_ar_on_you_24"
        app:tint="#64B5F6"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="72dp" />

    <!-- Nombre -->
    <TextView
        android:id="@+id/txtAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OCR Translate"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        app:layout_constraintTop_toBottomOf="@id/appIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Subtítulo -->
    <TextView
        android:id="@+id/txtSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Escanea · Detecta · Traduce"
        android:textColor="#888888"
        android:textSize="14sp"
        android:letterSpacing="0.08"
        app:layout_constraintTop_toBottomOf="@id/txtAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp" />

    <!-- Línea decorativa -->
    <View
        android:id="@+id/divider"
        android:layout_width="40dp"
        android:layout_height="2dp"
        android:background="#64B5F6"
        app:layout_constraintTop_toBottomOf="@id/txtSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <!-- ══════════════════════════════════════════
         BLOQUE DE ESTADO DEL MODELO
         Visible mientras descarga / invisible cuando listo
         ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutDescarga"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="40dp"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Ícono de estado (nube descargando / check) -->
        <ImageView
            android:id="@+id/iconEstado"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/stat_sys_download"
            app:tint="#64B5F6"
            android:layout_marginBottom="12dp" />

        <!-- Texto de estado -->
        <TextView
            android:id="@+id/txtEstadoModelo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preparando modelo de traducción..."
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Barra de progreso indeterminada mientras descarga -->
        <ProgressBar
            android:id="@+id/progressDescarga"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:indeterminate="true"
            android:progressTint="#1976D2"
            android:progressBackgroundTint="#333333"
            android:layout_marginBottom="8dp" />

        <!-- Texto pequeño de ayuda -->
        <TextView
            android:id="@+id/txtAyudaDescarga"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Esto solo ocurre la primera vez"
            android:textColor="#555555"
            android:textSize="12sp"
            android:gravity="center" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════
         BOTONES PRINCIPALES
         Deshabilitados mientras descarga
         ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutBotones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/layoutDescarga"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Botón Cámara en vivo -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnIrLive"
            android:layout_width="0dp"
            android:layout_height="160dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#1A1A2E"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:id="@+id/stripeLive"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:background="#1976D2"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/iconLive"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="#64B5F6"
                    app:layout_constraintTop_toBottomOf="@id/stripeLive"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@+id/txtLiveLabel"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/txtLiveLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cámara\nen vivo"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="18dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- Botón Galería -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnIrGaleria"
            android:layout_width="0dp"
            android:layout_height="160dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#1A1A2E"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:id="@+id/stripeGaleria"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:background="#7B1FA2"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/iconGaleria"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    app:tint="#CE93D8"
                    app:layout_constraintTop_toBottomOf="@id/stripeGaleria"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@+id/txtGaleriaLabel"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/txtGaleriaLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Desde\ngalería"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="18dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Texto inferior -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Inglés → Español"
        android:textColor="#444444"
        android:textSize="12sp"
        android:letterSpacing="0.1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp" />

</androidx.constraintlayout.widget.ConstraintLayout>